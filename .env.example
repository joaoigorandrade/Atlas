# Copy to .env.local and fill in. .env.local is gitignored — never commit keys.

# Required — your OpenRouter API key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — model slug used for all content generation.
# Default: deepseek/deepseek-chat (OpenRouter's alias for DeepSeek's latest V3
# flagship chat model — cheap and reliably structured).
# Other cheap models that handle this app's JSON well:
#   deepseek/deepseek-chat-v3.1   (pin a specific DeepSeek version)
#   openai/gpt-4o-mini
#   google/gemini-2.0-flash-001
#   google/gemini-2.5-flash-lite
OPENROUTER_MODEL=deepseek/deepseek-chat

# Optional — stronger model for answer judging (Socratic/Feynman/Crucible).
# Judging demands more reliability than content generation; defaults to
# OPENROUTER_MODEL when unset.
# OPENROUTER_JUDGE_MODEL=anthropic/claude-sonnet-4.5

# Optional — comma-separated fallback model chain, tried in order after the
# primary model's retries (429/5xx with backoff) exhaust.
# OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini,google/gemini-2.0-flash-001

# Optional — override the API base URL (tests / self-hosted gateways).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional — generation abuse limits (defaults shown).
# GENERATION_DAILY_QUOTA=60          # per-user calls per UTC day
# GENERATION_MONTHLY_CALL_CAP=20000  # global calls per month (spend ceiling)

# Supabase — auth (magic-link accounts) + run-state persistence.
# Find these under the project's Settings → API Keys. next.config.ts mirrors
# URL + publishable key into NEXT_PUBLIC_* for the browser bundle; RLS is the
# access control, so both are safe client-side.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only — used for account deletion (#33) and the reminders cron (#31),
# which read/delete across users. Never exposed to the browser.
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=

# Reminders cron (#31), all optional.
# CRON_SECRET       — Vercel Cron sends it as a Bearer token; set it to lock the route.
# RESEND_API_KEY    — enables actual email sends; without it reminders are logged only.
# REMINDER_FROM     — verified sender, e.g. "Atlas <hi@yourdomain>".
# APP_URL           — absolute app URL used in the reminder link.
# CRON_SECRET=
# RESEND_API_KEY=
# REMINDER_FROM=
# APP_URL=https://your-atlas.vercel.app
