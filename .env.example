# Copy to .env.local and fill in. .env.local is gitignored — never commit keys.

# Required — your OpenRouter API key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — model slug used for all content generation.
# Default: openai/gpt-4o-mini (cheap and reliably structured).
# Other cheap models that handle this app's JSON well:
#   google/gemini-2.0-flash-001
#   google/gemini-2.5-flash-lite
#   openai/gpt-4.1-mini
#   deepseek/deepseek-chat
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — override the API base URL (tests / self-hosted gateways).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
